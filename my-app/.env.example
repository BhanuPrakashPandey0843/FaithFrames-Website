# ── Firebase Admin (server-only writes for admin panel) ───────────────────────
# Option A: paste the full service account JSON on one line
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Option B: split credentials
FIREBASE_ADMIN_PROJECT_ID=wallpaper-c74a3
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ── Admin credentials (server-only — NEVER prefix with NEXT_PUBLIC_) ─────────
# These are checked on the server during login. Set strong values.
